function Expand-Payload {
    [System.IO.Directory]::CreateDirectory($PayloadRoot) | Out-Null
    [System.IO.File]::WriteAllBytes(
        $PayloadZip,
        [Convert]::FromBase64String($PayloadBase64.Trim())
    )

    Add-Type -AssemblyName System.IO.Compression.FileSystem
    [System.IO.Compression.ZipFile]::ExtractToDirectory($PayloadZip, $PayloadRoot)
}

function Invoke-Audit {
    Write-Step "Fase 0 - auditando checkout, pagamentos, assinatura e Mercado Pago legado"

    $roots = @("app", "components", "lib", "supabase")
    $patterns = @(
        "MercadoPago",
        "mercado-pago",
        "preapproval",
        "marketplace_fee",
        "payment_provider",
        "payment_transactions",
        "marketplace_payments",
        "subscriptions",
        "trial_used_at",
        "walletId",
        "Asaas",
        "split",
        "Pix",
        "creditCard",
        "webhook",
        "company_id",
        "order_id",
        "idempotency"
    )

    $files = New-Object System.Collections.Generic.List[object]

    foreach ($root in $roots) {
        $absolute = Join-Path $ProjectRoot $root
        if (-not (Test-Path -LiteralPath $absolute)) { continue }

        Get-ChildItem -LiteralPath $absolute -Recurse -File -ErrorAction SilentlyContinue |
            Where-Object {
                $_.FullName -notmatch '\\node_modules\\|\\.next\\|\\.git\\|\\.orcaly-backups\\|\\.orcaly-checkout-asaas\\' -and
                $_.Extension -in @(".ts", ".tsx", ".js", ".jsx", ".sql", ".json")
            } |
            ForEach-Object {
                $relative = $_.FullName.Substring($ProjectRoot.Length).TrimStart("\").Replace("\", "/")
                $content = ""
                try { $content = [IO.File]::ReadAllText($_.FullName) } catch {}

                $hits = @()
                foreach ($pattern in $patterns) {
                    if ($content.IndexOf($pattern, [StringComparison]::OrdinalIgnoreCase) -ge 0) {
                        $hits += $pattern
                    }
                }

                if ($hits.Count -gt 0 -or $relative -match '(?i)payment|checkout|assinatura|subscription|mercado|asaas|financeiro') {
                    [void]$files.Add([pscustomobject]@{
                        path = $relative
                        matches = @($hits | Sort-Object -Unique)
                        size = $_.Length
                    })
                }
            }
    }

    $audit = [ordered]@{
        generatedAt = (Get-Date).ToString("o")
        project = "Orcaly"
        projectRoot = $ProjectRoot
        files = @($files)
        existingMercadoPagoRoutes = @($files | Where-Object { $_.path -match '(?i)mercado-pago' } | ForEach-Object { $_.path })
        existingPaymentFiles = @($files | Where-Object { $_.path -match '(?i)payment|pagamento|checkout' } | ForEach-Object { $_.path })
        notes = @(
            "A auditoria nao le arquivos .env.",
            "Nenhuma credencial e incluida no resultado.",
            "Mercado Pago permanece preservado como legado."
        )
    }

    if (-not $DryRun) {
        Write-JsonFile $AuditPath $audit 14
    }

    Write-Success ("Auditoria concluida: " + $files.Count + " arquivos relacionados.")
    return $audit
}

function Get-PayloadEntries {
    if (-not (Test-Path -LiteralPath $PayloadRoot)) {
        Expand-Payload
    }

    return @(
        Get-ChildItem -LiteralPath $PayloadRoot -Recurse -File |
            ForEach-Object {
                $_.FullName.Substring($PayloadRoot.Length).TrimStart("\").Replace("\", "/")
            } |
            Sort-Object
    )
}

function Install-LegacyPageWrapper {
    param(
        [string]$PagePath,
        [string]$LegacyPath,
        [string]$SpecialPayloadPath,
        [string]$Marker
    )

    $page = Get-ProjectPath $PagePath
    $legacy = Get-ProjectPath $LegacyPath
    $special = Join-Path $PayloadRoot (Normalize-RelativePath $SpecialPayloadPath)
    $specialContent = [IO.File]::ReadAllText($special)

    if (Test-Path -LiteralPath $page -PathType Leaf) {
        $current = [IO.File]::ReadAllText($page)

        if ($current.IndexOf($Marker, [StringComparison]::OrdinalIgnoreCase) -ge 0) {
            Write-Info ("Wrapper ja instalado: " + $PagePath)
            return
        }

        $FunctionBaseline[$PagePath] = @(Get-FunctionInventory $current)

        if (-not (Test-Path -LiteralPath $legacy -PathType Leaf)) {
            [void](Update-ProjectFile $LegacyPath $current)
        }

        [void](Update-ProjectFile $PagePath $specialContent)
        return
    }

    if (-not (Test-Path -LiteralPath $legacy -PathType Leaf)) {
        $fallbackPage = @'
// ORCALY_ASAAS_PLATFORM_V1
export default function LegacyPageFallback() {
  return null;
}
'@
        [void](Update-ProjectFile $LegacyPath $fallbackPage)
    }

    [void](Update-ProjectFile $PagePath $specialContent)
}

function Install-LegacyRouteWrapper {
    param(
        [string]$RoutePath,
        [string]$LegacyPath,
        [string]$SpecialPayloadPath,
        [string]$Marker
    )

    $route = Get-ProjectPath $RoutePath
    $legacy = Get-ProjectPath $LegacyPath
    $special = Join-Path $PayloadRoot (Normalize-RelativePath $SpecialPayloadPath)
    $specialContent = [IO.File]::ReadAllText($special)

    if (Test-Path -LiteralPath $route -PathType Leaf) {
        $current = [IO.File]::ReadAllText($route)

        if ($current.IndexOf($Marker, [StringComparison]::OrdinalIgnoreCase) -ge 0) {
            Write-Info ("Wrapper ja instalado: " + $RoutePath)
            return
        }

        $FunctionBaseline[$RoutePath] = @(Get-FunctionInventory $current)

        if (-not (Test-Path -LiteralPath $legacy -PathType Leaf)) {
            [void](Update-ProjectFile $LegacyPath $current)
        }

        [void](Update-ProjectFile $RoutePath $specialContent)
        return
    }

    if (-not (Test-Path -LiteralPath $legacy -PathType Leaf)) {
        $fallbackRoute = @'
// ORCALY_ASAAS_PLATFORM_V1
import { NextResponse } from "next/server";

export async function POST() {
  return NextResponse.json(
    { error: "Provider legado nao configurado." },
    { status: 501 },
  );
}
'@
        [void](Update-ProjectFile $LegacyPath $fallbackRoute)
    }

    [void](Update-ProjectFile $RoutePath $specialContent)
}

