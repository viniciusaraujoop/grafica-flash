    Invoke-SandboxChecks

    if (-not $SkipLint -and $scripts -contains "lint") {
        $result = Invoke-NpmCommand "lint final" @("run", "lint") $LintAfterLog
        $LintFinal = if ($result.Passed) { "PASSOU" } else { "FALHOU" }
    }

    if (-not $SkipFinalBuild) {
        $result = Invoke-NpmCommand "build final" @("run", "build") $BuildAfterLog
        $BuildFinal = if ($result.Passed) { "PASSOU" } else { "FALHOU" }
        $FinalBuildPassed = $result.Passed

        if (-not $result.Passed) {
            Restore-AllChanges
            Write-Manifests
            Stop-OnCriticalFailure "O build final falhou. Os arquivos modificados foram restaurados."
        }
    } else {
