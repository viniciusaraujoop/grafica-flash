      valores: [
        { id: uid(), nome: 'P', ajuste_tipo: 'fixo', ajuste_valor: 0 },
        { id: uid(), nome: 'M', ajuste_tipo: 'fixo', ajuste_valor: 0 },
        { id: uid(), nome: 'G', ajuste_tipo: 'fixo', ajuste_valor: 5 },
        { id: uid(), nome: 'GG', ajuste_tipo: 'fixo', ajuste_valor: 8 },
      ],
    },
  ],
  alimenticio: [
    {
      id: uid(),
      nome: 'Sabor',
      obrigatorio: true,
