function normalizarPlano(value: unknown): PlanoId {
  if (value === 'basico' || value === 'profissional' || value === 'premium') return value
  return 'profissional'
}

function formatMoney(value: number) {
  return value.toLocaleString('pt-BR', {
    style: 'currency',
    currency: 'BRL',
  })
}

function formatDate(value?: string | null) {
  if (!value) return 'NÃ£o informado'
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return 'NÃ£o informado'

  return date.toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  })
}

function assinaturaEstaAtiva(empresa: Empresa | null) {
  if (!empresa) return false
  if (empresa.assinatura_status !== 'ativa') return false
  if (!empresa.assinatura_expira_em) return true
  return new Date(empresa.assinatura_expira_em) > new Date()
}

export default function AssinaturaPage() {
  const router = useRouter()

  const [empresa, setEmpresa] = useState<Empresa | null>(null)
  const [token, setToken] = useState('')
  const [emailUsuario, setEmailUsuario] = useState('')
  const [canManage, setCanManage] = useState(true)
  const [role, setRole] = useState('')
  const [planoSelecionado, setPlanoSelecionado] = useState<PlanoId>('profissional')
  const [carregando, setCarregando] = useState(true)
  const [processando, setProcessando] = useState(false)
  const [mensagem, setMensagem] = useState('')
  const [erro, setErro] = useState('')

  const planoAtual = planos[planoSelecionado]
  const ativa = assinaturaEstaAtiva(empresa)

  const statusLabel = useMemo(() => {
    if (!empresa) return 'Carregando'
    if (ativa) return 'Ativa'
    if (empresa.assinatura_status === 'pendente') return 'Pagamento pendente'
    if (empresa.assinatura_status === 'cancelada') return 'Cancelada'
    if (empresa.assinatura_status === 'vencida') return 'Vencida'
    return empresa.assinatura_status || 'Pendente'
  }, [empresa, ativa])

  async function carregarAssinatura() {
    setCarregando(true)
    setMensagem('')
    setErro('')

    const retorno = typeof window !== 'undefined' ? new URLSearchParams(window.location.search).get('assinatura') : null
    if (retorno === 'retorno') {
      setMensagem('Retorno recebido. Se o pagamento foi aprovado, o status serÃ¡ atualizado pelo Mercado Pago em instantes.')
    }

    const { data: sessionData } = await supabase.auth.getSession()
    const session = sessionData.session
    const accessToken = session?.access_token
    const user = session?.user

    if (!accessToken || !user) {
      router.push('/login')
      return
    }

    setToken(accessToken)
    setEmailUsuario(user.email || '')

    const currentResponse = await fetch('/api/company/current', {
      headers: {
        Authorization: `Bearer ${accessToken}`,
      },
    })

    const currentPayload = await currentResponse.json().catch(() => ({}))

    if (currentResponse.ok && currentPayload.company?.id) {
      const loaded = currentPayload.company as Empresa
      setEmpresa(loaded)
      setCanManage(Boolean(currentPayload.permissions?.can_subscription ?? currentPayload.permissions?.can_manage ?? true))
      setRole(currentPayload.role || '')

      const plano = normalizarPlano(loaded.assinatura_plano || loaded.plano)
      setPlanoSelecionado(plano)
      setCarregando(false)
      return
    }

    const { data, error } = await supabase
      .from('companies')
      .select('id, nome, email, plano, ativo, assinatura_status, assinatura_plano, assinatura_inicio, assinatura_expira_em, assinatura_ultimo_pagamento, assinatura_checkout_url')
      .or(`owner_id.eq.${user.id},tester_id.eq.${user.id}`)
      .limit(1)
      .maybeSingle()

    if (error) {
      setErro(`Erro ao buscar assinatura: ${error.message}`)
      setCarregando(false)
      return
    }

    if (!data) {
      setErro(currentPayload.error || 'Nenhuma empresa encontrada para esta conta.')
      setCarregando(false)
      return
    }

    const loaded = data as Empresa
    setEmpresa(loaded)
    setCanManage(true)
    setRole('dono')
    setPlanoSelecionado(normalizarPlano(loaded.assinatura_plano || loaded.plano))
    setCarregando(false)
  }

  async function renovarOuAlterarPlano() {
    if (!empresa?.id) {
      setErro('Empresa nÃ£o carregada. Recarregue a pÃ¡gina e tente de novo.')
      return
    }

    if (!canManage) {
      setErro('Seu perfil nÃ£o tem permissÃ£o para alterar a assinatura. PeÃ§a ao dono ou gerente da empresa.')
      return
    }

    setProcessando(true)
    setMensagem('Gerando checkout do Mercado Pago...')
    setErro('')

    try {
      const response = await fetch('/api/checkout/plano', {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          action: 'renew',
          plano: planoSelecionado,
          companyId: empresa.id,
          email: empresa.email || emailUsuario,
          nomeEmpresa: empresa.nome,
        }),
      })

      const payload = await response.json().catch(() => ({}))

      const checkoutUrl =
        payload.checkout_url ||
        payload.checkoutUrl ||
        payload.init_point ||
        payload.sandbox_init_point ||
        payload.url

      if (!response.ok) {
        const details = payload.details?.message || payload.message || ''
        throw new Error(payload.error || details || 'Erro ao gerar checkout.')
      }

      if (!checkoutUrl) {
        throw new Error('O Mercado Pago nÃ£o retornou o link de pagamento. Verifique o token e a resposta da API.')
      }

      window.location.assign(checkoutUrl)
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Erro desconhecido ao gerar checkout.'
      setErro(message)
      setMensagem('')
      setProcessando(false)
    }
  }

  async function sair() {
    await supabase.auth.signOut()
    router.push('/login')
  }

  useEffect(() => {
    carregarAssinatura()
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [])

  if (carregando) {
    return (
      <main className="flex min-h-screen items-center justify-center bg-[#f8fbff] px-4">
