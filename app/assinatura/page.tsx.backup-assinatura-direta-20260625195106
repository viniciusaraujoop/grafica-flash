              Renovar / alterar plano
            </h2>
            <p className="mt-3 font-semibold leading-7 text-slate-500">
              Selecione abaixo o plano desejado. O botÃ£o final deve redirecionar para o Mercado Pago imediatamente apÃ³s o checkout ser criado.
            </p>

            <div className="mt-6 grid gap-3">
              {(Object.keys(planos) as PlanoId[]).map((id) => {
                const plano = planos[id]
                const selected = planoSelecionado === id

                return (
                  <button
                    key={id}
