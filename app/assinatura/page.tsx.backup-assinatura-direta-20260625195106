                          {plano.recursos.map((item) => <li key={item}>â€¢ {item}</li>)}
                        </ul>
                      </div>

                      <p className="shrink-0 text-2xl font-black text-[#05245c]">
                        {formatMoney(plano.preco)}<span className="text-sm text-slate-500">/mÃªs</span>
                      </p>
                    </div>
                  </button>
                )
              })}
            </div>

            <div className="mt-6 rounded-3xl border border-blue-100 bg-[#f8fbff] p-5">
              <p className="text-sm font-bold text-slate-500">Plano selecionado</p>
              <h3 className="mt-1 text-2xl font-black text-[#071b3a]">{planoAtual.nome}</h3>
              <p className="mt-1 text-3xl font-black text-[#05245c]">{formatMoney(planoAtual.preco)}/mÃªs</p>
              <p className="mt-3 text-sm font-semibold leading-6 text-slate-600">
                Ao clicar no botÃ£o, o Mercado Pago abrirÃ¡ em outra etapa para concluir o pagamento do plano selecionado.
              </p>
            </div>

            <button
              type="button"
              onClick={renovarOuAlterarPlano}
              disabled={processando || !empresa?.id}
              className="mt-6 w-full rounded-2xl bg-[#05245c] px-6 py-4 font-black text-white shadow-lg shadow-blue-950/15 transition hover:bg-[#031a43] disabled:cursor-not-allowed disabled:opacity-60"
            >
              {processando ? 'Gerando checkout...' : 'Renovar / alterar plano'}
            </button>

            {empresa?.assinatura_checkout_url && (
              <a
                href={empresa.assinatura_checkout_url}
                target="_blank"
                rel="noreferrer"
                className="mt-3 block rounded-2xl border border-blue-100 bg-white px-6 py-4 text-center font-black text-[#05245c]"
              >
                Abrir Ãºltimo checkout gerado
              </a>
            )}
          </section>
        </section>
      </section>
    </main>
  )
}
