                      ['Enviadas', '78%'],
                      ['Visualizadas', '63%'],
                      ['Aprovadas', '41%'],
                    ].map(([label, width]) => (
                      <div key={label}>
                        <div className="flex justify-between text-xs font-black text-[#607895]">
                          <span>{label}</span>
                          <span>{width}</span>
                        </div>
                        <div className="mt-2 h-3 rounded-full bg-[#edf4ff]">
                          <div className="h-3 rounded-full bg-[#05245c]" style={{ width }} />
                        </div>
                      </div>
                    ))}
                  </div>
                </div>

                <div className="rounded-2xl bg-white p-4">
                  <p className="font-black text-[#071b3a]">Próximas ações</p>
                  <div className="mt-4 space-y-3">
                    {['Responder alteração', 'Cobrar proposta vista', 'Finalizar pedido pronto'].map((item) => (
                      <div key={item} className="rounded-xl bg-[#f5f8ff] px-3 py-3 text-sm font-black text-[#05245c]">{item}</div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="link-proprio" className="bg-white px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-6xl rounded-[2.5rem] border border-[#d7e3f3] bg-[#f8fbff] p-8 shadow-2xl shadow-[#05245c]/10 sm:p-12">
          <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Link próprio por empresa</p>
          <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
            Cada empresa ganha um endereço profissional para vender melhor.
          </h2>
          <p className="mx-auto mt-5 max-w-3xl text-lg font-semibold leading-8 text-[#607895]">
            Use no Instagram, WhatsApp, cartão, QR Code, anúncio e assinatura de e-mail. O cliente acessa, escolhe, pede orçamento e acompanha pelo link.
          </p>

          <div className="mx-auto mt-8 max-w-3xl rounded-[1.8rem] border border-[#d7e3f3] bg-white p-4 text-left shadow-xl shadow-[#05245c]/8">
            <div className="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p className="text-xs font-black uppercase tracking-[0.2em] text-[#607895]">Exemplo</p>
                <p className="mt-1 break-all text-2xl font-black text-[#05245c]">empresa.orcaly.com.br</p>
              </div>
              <Link href="/cadastro" className="rounded-2xl bg-[#05245c] px-5 py-4 text-center font-black text-white">
                Solicitar meu link
              </Link>
            </div>
          </div>
        </div>
      </section>

      <section id="segmentos" className="bg-[#f8fbff] px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-6xl">
          <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Funciona para vários segmentos</p>
          <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
            Onde existe pedido, orçamento ou serviço, existe bagunça para organizar.
          </h2>

          <div className="mt-10 flex flex-wrap justify-center gap-3">
            {segmentos.map((segmento) => (
              <span key={segmento} className="rounded-full border border-[#d7e3f3] bg-white px-5 py-3 text-sm font-black text-[#05245c] shadow-sm">
                {segmento}
              </span>
            ))}
          </div>
        </div>
      </section>

      <section id="simulador" className="bg-white px-4 py-14 sm:py-20 sm:px-6 lg:px-8">
        <div className="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div className="text-center lg:text-left">
            <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Simulador de oportunidade perdida</p>
            <h2 className="mt-4 home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
              Quanto custa perder orçamento por falta de organização?
            </h2>
            <p className="mt-5 text-lg font-semibold leading-8 text-[#607895]">
              Ajuste os números e veja uma estimativa simples. Não é previsão financeira, é só um lembrete elegante de que desorganização também manda boleto.
            </p>
          </div>

          <div className="rounded-[2rem] border border-[#d7e3f3] bg-[#f8fbff] p-6 shadow-2xl shadow-[#05245c]/10">
            <div className="grid gap-5">
              <label className="grid gap-3">
                <span className="font-black text-[#071b3a]">Pedidos/orçamentos por mês: {pedidosMes}</span>
                <input min={5} max={300} type="range" value={pedidosMes} onChange={(event) => setPedidosMes(Number(event.target.value))} />
              </label>

              <label className="grid gap-3">
                <span className="font-black text-[#071b3a]">Ticket médio: {formatMoney(ticketMedio)}</span>
                <input min={50} max={2500} step={10} type="range" value={ticketMedio} onChange={(event) => setTicketMedio(Number(event.target.value))} />
              </label>

              <label className="grid gap-3">
                <span className="font-black text-[#071b3a]">Oportunidades perdidas: {taxaPerda}%</span>
                <input min={5} max={70} type="range" value={taxaPerda} onChange={(event) => setTaxaPerda(Number(event.target.value))} />
              </label>
            </div>

            <div className="mt-6 grid gap-4 sm:grid-cols-2">
              <div className="rounded-[1.5rem] bg-white p-5">
                <p className="text-sm font-black uppercase tracking-[0.16em] text-[#607895]">Perda estimada/mês</p>
                <p className="mt-2 text-3xl font-black text-[#05245c] sm:text-4xl">{formatMoney(perdaMensal)}</p>
              </div>
              <div className="rounded-[1.5rem] bg-[#05245c] p-5 text-white">
                <p className="text-sm font-black uppercase tracking-[0.16em] text-white/60">Perda estimada/ano</p>
                <p className="mt-2 text-3xl font-black sm:text-4xl">{formatMoney(perdaAnual)}</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="antes-depois" className="bg-[#05245c] px-4 py-14 sm:py-20 text-white sm:px-6 lg:px-8">
        <div className="mx-auto max-w-6xl">
          <div className="text-center">
            <p className="text-sm font-black uppercase tracking-[0.24em] text-[#b9d6ff]">Antes e depois</p>
            <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] sm:text-5xl lg:text-6xl">
              A diferença aparece no atendimento.
            </h2>
          </div>

          <div className="mt-10 overflow-hidden rounded-[2rem] border border-white/15 bg-white/10 shadow-2xl shadow-black/10 backdrop-blur">
            <div className="grid grid-cols-2 border-b border-white/15 bg-white/10">
              <div className="p-3 text-xs font-black uppercase tracking-[0.14em] text-white/60 sm:p-5 sm:text-sm sm:tracking-[0.18em]">Antes</div>
              <div className="p-3 text-xs font-black uppercase tracking-[0.14em] text-[#b9ffd4] sm:p-5 sm:text-sm sm:tracking-[0.18em]">Depois do Orçaly</div>
            </div>

            {antesDepois.map(([antes, depois]) => (
              <div key={antes} className="grid grid-cols-2 border-b border-white/10 last:border-0">
                <div className="break-words p-3 text-sm font-bold text-white/72 sm:p-5 sm:text-base">{antes}</div>
                <div className="break-words p-3 text-sm font-black text-white sm:p-5 sm:text-base">{depois}</div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="recursos" className="bg-white px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-6xl">
          <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Recursos principais</p>
          <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
            O que realmente ajuda a vender e operar melhor.
          </h2>

          <div className="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
            {recursos.map((recurso) => (
              <article key={recurso.titulo} className="rounded-[2rem] border border-[#e5edf8] bg-[#f8fbff] p-6 text-left shadow-lg shadow-[#05245c]/5 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#05245c]/10">
                <div className="mb-5 flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-sm font-black text-[#05245c] shadow-sm">✓</div>
                <h3 className="text-xl font-black text-[#071b3a]">{recurso.titulo}</h3>
                <p className="mt-3 text-sm font-semibold leading-6 text-[#607895]">{recurso.texto}</p>
              </article>
            ))}
          </div>

          <p className="mx-auto mt-8 max-w-3xl rounded-[1.5rem] border border-[#d7e3f3] bg-[#f8fbff] px-5 py-4 font-bold leading-7 text-[#526b88]">
            Evoluindo para automações, pagamentos, recuperação de orçamento e inteligência comercial.
          </p>
        </div>
      </section>

      <section id="como-funciona" className="bg-[#f8fbff] px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-6xl">
          <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Como funciona</p>
          <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
            Em três passos, a empresa sai do improviso.
          </h2>

          <div className="mt-10 grid gap-5 md:grid-cols-3">
            {passos.map((passo) => (
              <article key={passo.numero} className="rounded-[2rem] border border-[#e5edf8] bg-white p-8 text-left shadow-xl shadow-[#05245c]/5">
                <p className="text-4xl font-black text-[#05245c] sm:text-5xl">{passo.numero}</p>
                <h3 className="mt-5 text-2xl font-black text-[#071b3a]">{passo.titulo}</h3>
                <p className="mt-3 font-semibold leading-7 text-[#607895]">{passo.texto}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="planos" className="bg-white px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-7xl">
          <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">Planos</p>
          <h2 className="mx-auto mt-4 max-w-4xl home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
            Comece simples e evolua conforme a operação cresce.
          </h2>

          <div className="mt-10 grid gap-5 lg:grid-cols-3">
            {planos.map((plano) => (
              <article
                key={plano.id}
                className={`relative rounded-[2rem] border p-7 text-left shadow-xl transition hover:-translate-y-1 ${
                  plano.destaque
                    ? 'border-[#05245c] bg-[#05245c] text-white shadow-[#05245c]/20'
                    : 'border-[#e5edf8] bg-[#f8fbff] text-[#071b3a] shadow-[#05245c]/5'
                }`}
              >
                {plano.destaque && (
                  <span className="mb-4 inline-flex rounded-full bg-white px-3 py-1 text-xs font-black uppercase tracking-[0.16em] text-[#05245c]">
                    Mais escolhido
                  </span>
                )}

                <h3 className="text-3xl font-black">{plano.nome}</h3>
                <p className={`mt-2 font-semibold leading-7 ${plano.destaque ? 'text-white/72' : 'text-[#607895]'}`}>{plano.descricao}</p>
                <p className="mt-6 text-4xl font-black">{plano.preco}<span className={`text-base ${plano.destaque ? 'text-white/60' : 'text-[#607895]'}`}>/mês</span></p>

                <div className="mt-6 grid gap-3">
                  {plano.recursos.map((recurso) => (
                    <div key={recurso} className={`flex gap-3 rounded-2xl px-4 py-3 text-sm font-black ${plano.destaque ? 'bg-white/10 text-white' : 'bg-white text-[#05245c]'}`}>
                      <span>✓</span>
                      <span>{recurso}</span>
                    </div>
                  ))}
                </div>

                <Link
                  href="/cadastro"
                  className={`mt-7 inline-flex w-full justify-center rounded-2xl px-5 py-4 font-black ${
                    plano.destaque ? 'bg-white text-[#05245c]' : 'bg-[#05245c] text-white'
                  }`}
                >
                  Solicitar acesso antecipado
                </Link>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="faq" className="bg-[#f8fbff] px-4 py-14 sm:py-20 sm:px-6 lg:px-8">
        <div className="mx-auto max-w-5xl">
          <div className="text-center">
            <p className="text-sm font-black uppercase tracking-[0.24em] text-[#05245c]">FAQ</p>
            <h2 className="mt-4 home-heading text-3xl font-black leading-tight tracking-[-0.035em] text-[#061a36] sm:text-5xl lg:text-6xl">
              Perguntas frequentes
            </h2>
          </div>

          <div className="mt-10 grid gap-4">
            {faqs.map((faq) => (
              <details key={faq.pergunta} className="group rounded-[1.5rem] border border-[#e5edf8] bg-white p-6 shadow-lg shadow-[#05245c]/5">
                <summary className="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-xl font-black text-[#071b3a]">
                  {faq.pergunta}
                  <span className="rounded-full bg-[#f5f8ff] px-3 py-1 text-[#05245c] transition group-open:rotate-45">+</span>
                </summary>
                <p className="mt-4 font-semibold leading-7 text-[#607895]">{faq.resposta}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section className="bg-white px-4 py-14 sm:py-20 text-center sm:px-6 lg:px-8">
        <div className="mx-auto max-w-5xl rounded-[2.5rem] border border-[#d7e3f3] bg-[#05245c] p-8 text-white shadow-2xl shadow-[#05245c]/20 sm:p-12">
          <img src="/icone-orcaly.png" alt="Ícone Orçaly" className="mx-auto h-12 w-12 object-contain sm:h-16 sm:w-16" />
          <h2 className="mt-6 home-heading text-3xl font-black leading-tight tracking-[-0.035em] sm:text-5xl lg:text-6xl">
            Pronto para transformar pedidos em vendas organizadas?
          </h2>
          <p className="mx-auto mt-5 max-w-2xl text-lg font-semibold leading-8 text-white/75">
            Comece com uma página própria, receba orçamentos e acompanhe cada oportunidade em um só lugar.
          </p>

          <div className="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
            <Link href="/cadastro" className="rounded-[1.4rem] bg-white px-8 py-5 font-black text-[#05245c] shadow-xl shadow-black/10">
              Solicitar acesso antecipado
            </Link>
            <a href="#planos" className="rounded-[1.4rem] border border-white/20 bg-white/10 px-8 py-5 font-black text-white">
              Ver planos
            </a>
          </div>
        </div>
      </section>

      <footer className="border-t border-[#e5edf8] bg-white px-4 py-8 text-center">
        <img src="/logo-orcaly.png" alt="Orçaly" className="mx-auto h-10 w-auto object-contain" />
        <p className="mx-auto mt-4 max-w-2xl text-sm font-bold leading-6 text-[#607895]">
          Orçaly, pedidos inteligentes, propostas profissionais e operação organizada para empresas que querem vender melhor.
        </p>
      </footer>

      <div className="fixed inset-x-0 bottom-0 z-50 border-t border-[#d7e3f3] bg-white/95 p-3 shadow-2xl shadow-[#05245c]/15 backdrop-blur sm:hidden">
        <div className="grid grid-cols-2 gap-2">
          <a href="#como-funciona" className="rounded-2xl border border-[#d7e3f3] bg-white px-4 py-3 text-center text-sm font-black text-[#05245c]">
            Como funciona
          </a>
          <Link href="/cadastro" className="rounded-2xl bg-[#05245c] px-4 py-3 text-center text-sm font-black text-white">
            Começar
          </Link>
        </div>
      </div>
    </main>
  )
}
