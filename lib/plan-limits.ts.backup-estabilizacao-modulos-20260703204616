export function normalizePlanId(value: unknown): NormalizedPlanId {
  if (value === 'premium') return 'premium'
  if (value === 'profissional' || value === 'intermediate' || value === 'intermediario') return 'intermediate'
  if (value === 'basico' || value === 'basic' || value === 'essencial') return 'basic'
  return 'intermediate'
}

export function getPlanLimits(plan: unknown) {
  return planLimits[normalizePlanId(plan)]
}

export function canUseFeature(plan: unknown, feature: PlanFeature) {
  return getPlanLimits(plan).features.includes(feature)
}

export function getRequiredPlan(feature: PlanFeature): NormalizedPlanId | null {
  if (planLimits.basic.features.includes(feature)) return 'basic'
  if (planLimits.intermediate.features.includes(feature)) return 'intermediate'
  if (planLimits.premium.features.includes(feature)) return 'premium'
  return null
}

export function getUpgradeMessage(feature: PlanFeature) {
  const required = getRequiredPlan(feature)
  if (!required) return 'Recurso em preparação.'

  return `Recurso disponível no plano ${planLimits[required].label}.`
}

export function planCanAccess(requiredPlan: NormalizedPlanId | null | undefined, currentPlan: unknown) {
  if (!requiredPlan) return true

  const order: Record<NormalizedPlanId, number> = {
    basic: 1,
    intermediate: 2,
    premium: 3,
  }

  return order[normalizePlanId(currentPlan)] >= order[requiredPlan]
}
