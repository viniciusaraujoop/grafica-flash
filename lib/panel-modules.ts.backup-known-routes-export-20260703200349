export function normalizeBusinessTypeForModules(value: unknown): BusinessType {
  const normalized = String(value || 'services')
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9_]/g, '_')
    .replace(/_+/g, '_')
    .replace(/^_|_$/g, '')

  const aliases: Record<string, BusinessType> = {
    servicos: 'services',
    servicos_gerais: 'services',
    services: 'services',
    grafica: 'graphic',
    graphic: 'graphic',
    alimenticio: 'food',
    food: 'food',
    restaurante: 'food',
    lanchonete: 'food',
    beleza: 'beauty',
    estetica: 'beauty',
    beauty: 'beauty',
    barbearia: 'barber',
    barber: 'barber',
    assistencia: 'technical_assistance',
    assistencia_tecnica: 'technical_assistance',
    technical_assistance: 'technical_assistance',
    oficina: 'auto',
    auto: 'auto',
    automotivo: 'auto',
    loja: 'store',
    comercio: 'store',
    store: 'store',
    eventos: 'events',
    events: 'events',
    personalizados: 'custom_products',
    custom_products: 'custom_products',
  }

  return aliases[normalized] || 'services'
}

function isRouteAvailable(href: string) {
  if (href.startsWith('http')) return true
  if (href.startsWith('/painel/modulos/')) return true
  return existingPanelRoutes.has(href)
}

export function getSafeModuleHref(module: PanelModule) {
  if (isRouteAvailable(module.href)) return module.href
  if (module.fallbackHref && isRouteAvailable(module.fallbackHref)) return module.fallbackHref
  return `/painel/modulos/${module.id.replace(/_/g, '-')}`
}

export function getModuleById(id: string) {
  const normalized = id.replace(/-/g, '_')

  return panelModules.find((module) => {
    const aliases = module.aliases || []
    return module.id === id || module.id === normalized || aliases.includes(id) || aliases.includes(normalized)
  })
}

export function getModulesForBusinessType(businessType: unknown) {
  const normalized = normalizeBusinessTypeForModules(businessType)

  return panelModules
    .filter((module) => module.isGlobal || module.segments.includes(normalized))
    .map((module) => ({ ...module, href: getSafeModuleHref(module) }))
}

export function getModulesByGroup(businessType: unknown) {
  const groupOrder: ModuleGroup[] = [
    'principal',
    'comercial',
    'operacao',
    'financeiro',
    'presenca_digital',
    'sistema',
    'administracao',
  ]

  const modules = getModulesForBusinessType(businessType)

  return groupOrder
    .map((group) => ({
      group,
      label: moduleGroupLabels[group],
      modules: modules.filter((module) => module.group === group),
    }))
    .filter((group) => group.modules.length > 0)
}

function quick(id: string, title?: string, description?: string, badge?: string): PanelQuickAction | null {
  const module = getModuleById(id)
  if (!module) return null

  return {
    title: title || module.label,
    description: description || module.description,
    href: getSafeModuleHref(module),
    badge,
    requiredPlan: module.requiredPlan,
  }
}

function unique(actions: Array<PanelQuickAction | null>) {
  const labels = new Set<string>()
  const result: PanelQuickAction[] = []

  for (const action of actions) {
    if (!action) continue
    if (labels.has(action.title)) continue
    labels.add(action.title)
    result.push(action)
  }

  return result
}

